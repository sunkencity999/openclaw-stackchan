# NOTE (portable copy): paths use %h (your home dir). This unit assumes the repo
# is checked out at %h/.openclaw/workspace/stackchan and daemon scripts at
# %h/.openclaw/workspace/scripts/. Edit paths below to match YOUR install,
# then: cp stackchan-presence.service ~/.config/systemd/user/ && systemctl --user daemon-reload
#       systemctl --user enable --now stackchan-presence.service

[Unit]
Description=StackChan presence watcher (camera/mic/BLE → greeting trigger)
Documentation=file://%h/.openclaw/workspace/stackchan/README.md
After=stackchan-gateway.service network-online.target bluetooth.target
Wants=stackchan-gateway.service
PartOf=stackchan-gateway.service

[Service]
Type=simple
WorkingDirectory=%h/.openclaw/workspace
ExecStart=%h/.local/share/uv/tools/stackchan-mcp/bin/python %h/.openclaw/workspace/scripts/presence_watcher.py run
Restart=on-failure
RestartSec=10s
StandardOutput=append:%h/.openclaw/workspace/stackchan/presence/logs/watcher.log
StandardError=append:%h/.openclaw/workspace/stackchan/presence/logs/watcher.log

[Install]
WantedBy=default.target
